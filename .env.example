FILESTORE_API_LISTEN=:8080
FILESTORE_API_READ_HEADER_TIMEOUT=5s
FILESTORE_API_SHUTDOWN_TIMEOUT=10s
FILESTORE_AUTH_TOKEN_TTL=24h
FILESTORE_MAX_FILE_SIZE=104857600
FILESTORE_UPDATE_SESSION_TTL=24h
FILESTORE_DIFF_MAX_INPUT_BYTES=1048576
FILESTORE_DIFF_MAX_LINES=20000
FILESTORE_DIFF_MAX_OUTPUT_BYTES=1048576
FILESTORE_ORPHAN_GRACE_PERIOD=24h
FILESTORE_TEXT_ENCODINGS=utf-8,utf-16le,utf-16be,windows-1251
FILESTORE_S3_ENDPOINT=http://localhost:8333
FILESTORE_S3_REGION=us-east-1
FILESTORE_S3_BUCKET=filestore
FILESTORE_S3_ACCESS_KEY=filestore
FILESTORE_S3_SECRET_KEY=filestore-local
FILESTORE_DATABASE_URL=postgres://filestore:filestore-local@localhost:5432/filestore?sslmode=disable
POSTGRES_USER=filestore
POSTGRES_PASSWORD=filestore-local
POSTGRES_DB=filestore
PGADMIN_DEFAULT_EMAIL=admin@example.test
PGADMIN_DEFAULT_PASSWORD=admin-password-123
PGADMIN_PORT=5050
# FILESTORE_CONFIG=C:\path\to\filestore.config.json
